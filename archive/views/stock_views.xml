<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="view_assetflow_stock_list" model="ir.ui.view">
            <field name="name">assetflow.stock.list</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <tree string="Inventory &amp; Stock Health"
                      decoration-danger="needs_reorder == True"
                      >
                    <field name="product_id" string="Product / Item"/>
                    <field name="quantity" string="Current Stock"/>
                    <field name="monthly_consumption" string="Monthly Consumption"/>
                    <field name="avg_monthly_consumption" string="Avg. Monthly Consumption" optional="show"/>
                    <field name="predicted_reorder_date" string="Predicted Reorder Date"/>
                    <field name="needs_reorder" string="Needs Reorder"/>
                </tree>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_assetflow_stock_form" model="ir.ui.view">
            <field name="name">assetflow.stock.form</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <form string="Stock Item Detail">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="product_id" placeholder="Product / Item"/></h1>
                        </div>
                        <group>
                            <group string="Current Levels">
                                <field name="quantity"/>
                                <field name="avg_monthly_consumption"/>
                            </group>
                            <group string="Forecast &amp; Reorder">
                                <field name="monthly_consumption"/>
                                <field name="predicted_reorder_date"/>
                            </group>
                        </group>
                        <group string="Health Status">
                            <field name="needs_reorder" string="Needs Reorder"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="view_assetflow_stock_search" model="ir.ui.view">
            <field name="name">assetflow.stock.search</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <search string="Search Stock">
                    <field name="product_id"/>
                    <filter string="Needs Reorder" name="filter_needs_reorder"
                            domain="[('needs_reorder','=',True)]"/>
                                                            <group expand="0" string="Group By">
                        <filter string="Inventory Health" name="group_status" context="{'group_by': 'needs_reorder'}"/>
                        <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- WINDOW ACTION -->
        <record id="action_assetflow_stock" model="ir.actions.act_window">
            <field name="name">Stock Levels &amp; Health</field>
            <field name="res_model">stock.quant</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_needs_reorder': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No custom inventory extension records found.
                </p>
                <p>
                    Data from models/stock_extension.py will compile predictive health insights here.
                </p>
            </field>
        </record>

    </data>
</odoo>