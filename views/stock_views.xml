<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="view_assetflow_stock_list" model="ir.ui.view">
            <field name="name">assetflow.stock.list</field>
            <field name="model">assetflow.stock</field>
            <field name="arch" type="xml">
                <list string="Inventory &amp; Stock Health"
                      decoration-danger="inventory_status == 'critical'"
                      decoration-warning="inventory_status == 'low'">
                    <field name="product_id" string="Product / Item"/>
                    <field name="qty_available" string="Current Stock"/>
                    <field name="forecast_demand" string="Forecast Demand"/>
                    <field name="avg_consumption" string="Avg. Monthly Consumption" optional="show"/>
                    <field name="predicted_reorder_date" string="Predicted Reorder Date"/>
                    <field name="inventory_status" string="Inventory Health" widget="badge"
                           decoration-success="inventory_status == 'healthy'"
                           decoration-warning="inventory_status == 'low'"
                           decoration-danger="inventory_status == 'critical'"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_assetflow_stock_form" model="ir.ui.view">
            <field name="name">assetflow.stock.form</field>
            <field name="model">assetflow.stock</field>
            <field name="arch" type="xml">
                <form string="Stock Item Detail">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="product_id" placeholder="Product / Item"/></h1>
                        </div>
                        <group>
                            <group string="Current Levels">
                                <field name="qty_available"/>
                                <field name="avg_consumption"/>
                            </group>
                            <group string="Forecast &amp; Reorder">
                                <field name="forecast_demand"/>
                                <field name="predicted_reorder_date"/>
                            </group>
                        </group>
                        <group string="Health Status">
                            <field name="inventory_status" widget="badge"
                                   decoration-success="inventory_status == 'healthy'"
                                   decoration-warning="inventory_status == 'low'"
                                   decoration-danger="inventory_status == 'critical'"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="view_assetflow_stock_search" model="ir.ui.view">
            <field name="name">assetflow.stock.search</field>
            <field name="model">assetflow.stock</field>
            <field name="arch" type="xml">
                <search string="Search Stock">
                    <field name="product_id"/>
                    <filter string="Needs Reorder" name="filter_needs_reorder"
                            domain="[('inventory_status','in',('low','critical'))]"/>
                    <filter string="Critical" name="filter_critical" domain="[('inventory_status','=','critical')]"/>
                    <filter string="Healthy" name="filter_healthy" domain="[('inventory_status','=','healthy')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Inventory Health" name="group_status" context="{'group_by': 'inventory_status'}"/>
                        <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- WINDOW ACTION -->
        <record id="action_assetflow_stock" model="ir.actions.act_window">
            <field name="name">Stock Levels &amp; Health</field>
            <field name="res_model">assetflow.stock</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_needs_reorder': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No custom inventory extension records found.
                </p>
                <p>
                    Data from models/stock_extension.py will compile predictive health insights here.
                </p>
            </field>
        </record>

    </data>
</odoo>