<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="view_assetflow_forecast_list" model="ir.ui.view">
            <field name="name">assetflow.demand.forecast.list</field>
            <field name="model">assetflow.demand.forecast</field>
            <field name="arch" type="xml">
                <tree string="Demand Forecasts"
                      decoration-danger="accuracy &lt; 80">
                    <field name="product_id"/>
                    <field name="forecast_date"/>
                    <field name="predicted_qty" sum="Total Forecast"/>
                    <field name="actual_qty" sum="Total Actual"/>
                                                            <field name="reorder_suggested" widget="boolean_toggle"/>
                </tree>
            </field>
        </record>

        <!-- GRAPH VIEW: Forecast vs Actual over time -->
        <record id="view_assetflow_forecast_graph" model="ir.ui.view">
            <field name="name">assetflow.demand.forecast.graph</field>
            <field name="model">assetflow.demand.forecast</field>
            <field name="arch" type="xml">
                <graph string="Forecast vs Actual Demand" type="line">
                    <field name="forecast_date" type="row" interval="month"/>
                    <field name="predicted_qty" type="measure"/>
                    <field name="actual_qty" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- PIVOT VIEW: Monthly demand / inventory trend breakdown -->
        <record id="view_assetflow_forecast_pivot" model="ir.ui.view">
            <field name="name">assetflow.demand.forecast.pivot</field>
            <field name="model">assetflow.demand.forecast</field>
            <field name="arch" type="xml">
                <pivot string="Inventory Trend Analysis">
                    <field name="product_id" type="row"/>
                    <field name="forecast_date" type="col" interval="month"/>
                    <field name="predicted_qty" type="measure"/>
                    <field name="actual_qty" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="view_assetflow_forecast_search" model="ir.ui.view">
            <field name="name">assetflow.demand.forecast.search</field>
            <field name="model">assetflow.demand.forecast</field>
            <field name="arch" type="xml">
                <search string="Search Forecasts">
                    <field name="product_id"/>
                    <field name="forecast_date"/>
                    <filter string="Needs Reorder" name="filter_reorder" domain="[('reorder_suggested','=',True)]"/>
                    <filter string="This Month" name="filter_this_month"
                            domain="[('forecast_date','&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                        <filter string="Month" name="group_month" context="{'group_by': 'forecast_date:month'}"/>
                        <filter string="Inventory Health" name="group_health" context="{'group_by': 'reorder_suggested'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_assetflow_forecast" model="ir.actions.act_window">
            <field name="name">Forecasts</field>
            <field name="res_model">assetflow.demand.forecast</field>
            <field name="view_mode">graph,list,pivot</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No forecast data available yet</p>
            </field>
        </record>

    </data>
</odoo>