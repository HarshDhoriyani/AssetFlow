<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ================= Module Category ================= -->
        <record id="module_category_assetflow" model="ir.module.category">
            <field name="name">AssetFlow</field>
            <field name="description">Enterprise Asset &amp; Resource Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- ================= Groups ================= -->
        <record id="group_assetflow_read_only" model="res.groups">
            <field name="name">Read Only</field>
            <field name="category_id" ref="module_category_assetflow"/>
        </record>

        <record id="group_assetflow_finance" model="res.groups">
            <field name="name">Finance</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_read_only'))]"/>
        </record>

        <record id="group_assetflow_technician" model="res.groups">
            <field name="name">Technician</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_read_only'))]"/>
        </record>

        <record id="group_assetflow_auditor" model="res.groups">
            <field name="name">Auditor</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_read_only'))]"/>
        </record>

        <record id="group_assetflow_department_head" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_read_only'))]"/>
        </record>

        <record id="group_assetflow_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_department_head')),
                                             (4, ref('group_assetflow_technician')),
                                             (4, ref('group_assetflow_auditor')),
                                             (4, ref('group_assetflow_finance'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ================= Record Rules ================= -->

        <!-- Asset Manager: full access to all assets in their company -->
        <record id="rule_asset_manager_all" model="ir.rule">
            <field name="name">Asset Manager: all assets (company)</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Department Head: only assets allocated within their own department -->
        <record id="rule_department_head_assets" model="ir.rule">
            <field name="name">Department Head: own department assets</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="groups" eval="[(4, ref('group_assetflow_department_head'))]"/>
            <field name="domain_force">
                [('allocation_ids.department_id.manager_id.user_id', '=', user.id)]
            </field>
        </record>

        <!-- Technician: only maintenance requests assigned to them -->
        <record id="rule_technician_maintenance" model="ir.rule">
            <field name="name">Technician: assigned maintenance requests</field>
            <field name="model_id" ref="model_assetflow_maintenance_request"/>
            <field name="groups" eval="[(4, ref('group_assetflow_technician'))]"/>
            <field name="domain_force">
                [('assigned_to.user_id', '=', user.id)]
            </field>
        </record>

        <!-- Auditor: only audit cycles they participate in -->
        <record id="rule_auditor_cycles" model="ir.rule">
            <field name="name">Auditor: own audit cycles</field>
            <field name="model_id" ref="model_assetflow_audit_cycle"/>
            <field name="groups" eval="[(4, ref('group_assetflow_auditor'))]"/>
            <field name="domain_force">
                [('auditor_ids', 'in', [user.id])]
            </field>
        </record>

        <!-- Read Only: global read on core models, no write, enforced via ACL -->
        <record id="rule_read_only_assets" model="ir.rule">
            <field name="name">Read Only: all assets (view only)</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="groups" eval="[(4, ref('group_assetflow_read_only'))]"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
